# Job Radar — Environment Variables
#
# Copy this file to .env and fill in values.
# The app works without these (uses localStorage only).
# Add Supabase credentials to enable cross-device persistence.

# Supabase (optional — for persistent cross-device storage)
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Email digest (used by GitHub Actions only)
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=
# RECIPIENT_EMAIL=
# DASHBOARD_URL=       # where the email's "Open Dashboard" button links (has a default)
